{
  "name": "@radioboi/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "next dev --turbopack --hostname 127.0.0.1 -p 3100",
    "build": "next build",
    "start": "node .next/standalone/apps/web/server.js",
    "lint": "biome lint ./app ./src",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next .open-next dist"
  },
  "dependencies": {
    "@msgpack/msgpack": "3.1.3",
    "@opennextjs/cloudflare": "1.19.10",
    "@radioboi/game-core": "workspace:*",
    "@radioboi/morse-engine": "workspace:*",
    "comlink": "4.4.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
