{
  "name": "@radioboi/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "next dev --turbopack --hostname 127.0.0.1 -p 3100",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint ./app ./src",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next .open-next dist"
  },
  "dependencies": {
    "@msgpack/msgpack": "latest",
    "@opennextjs/cloudflare": "latest",
    "@radioboi/game-core": "workspace:*",
    "@radioboi/morse-engine": "workspace:*",
    "comlink": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "babel-plugin-react-compiler": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
